{
  "name": "@im/chat-sdk",
  "version": "1.0.0",
  "description": "Type-safe Chat SDK for Go-Chat IM service",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "chat",
    "sdk",
    "websocket",
    "im",
    "instant-messaging",
    "typescript"
  ],
  "author": "sanbei101",
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}